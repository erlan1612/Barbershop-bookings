{
  "name": "barbershop-booking-api",
  "version": "1.0.0",
  "description": "Backend API for barbershop booking MVP",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed:refresh": "node scripts/seed_refresh.js",
    "migrate:up": "node-pg-migrate up -m db/migrations",
    "migrate:down": "node-pg-migrate down -m db/migrations",
    "migrate:create": "node-pg-migrate create -m db/migrations",
    "test:smoke": "node --test tests/smoke.test.js",
    "test:integration": "node --test tests/integration.test.js",
    "test": "npm run test:smoke && npm run test:integration",
    "test:ci": "npm run migrate:up && npm run seed:refresh && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "node-pg-migrate": "^8.0.3",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.4"
  }
}
