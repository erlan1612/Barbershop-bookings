{
  "info": {
    "name": "Barbershop Booking API",
    "description": "Postman collection for testing Barbershop Booking API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health returns 200', () => {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Barbers",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/barbers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "barbers"
          ]
        }
      }
    },
    {
      "name": "Get Services",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/services",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "services"
          ]
        }
      }
    },
    {
      "name": "Get Slots",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/slots?date={{date}}&barberId={{barberId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "slots"
          ],
          "query": [
            {
              "key": "date",
              "value": "{{date}}"
            },
            {
              "key": "barberId",
              "value": "{{barberId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"{{userFullName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"{{userPhone}}\",\n  \"password\": \"{{userPassword}}\"\n}\n"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register returns 201 or 409', () => {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "User Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}\n"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login returns token', () => {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.be.a('string');",
              "  pm.collectionVariables.set('userToken', json.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUser}}\",\n  \"password\": \"{{adminPassword}}\"\n}\n"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin login returns token', () => {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.be.a('string');",
              "  pm.collectionVariables.set('adminToken', json.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Slots (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"barberId\": {{barberId}},\n  \"date\": \"{{date}}\",\n  \"times\": [\"10:00\", \"10:30\", \"11:00\"],\n  \"status\": \"available\"\n}\n"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/slots",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "slots"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Create slots returns 201', () => {",
              "  pm.response.to.have.status(201);",
              "  const json = pm.response.json();",
              "  if (json.created && json.created.length > 0) {",
              "    pm.collectionVariables.set('slotId', json.created[0].id);",
              "  }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Booking (User)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"serviceId\": {{serviceId}},\n  \"barberId\": {{barberId}},\n  \"date\": \"{{date}}\",\n  \"time\": \"{{time}}\"\n}\n"
        },
        "url": {
          "raw": "{{baseUrl}}/api/bookings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bookings"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Create booking returns 201', () => {",
              "  pm.response.to.have.status(201);",
              "  const json = pm.response.json();",
              "  pm.collectionVariables.set('bookingId', json.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Bookings (Admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/bookings?date={{date}}&barberId={{barberId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "bookings"
          ],
          "query": [
            {
              "key": "date",
              "value": "{{date}}"
            },
            {
              "key": "barberId",
              "value": "{{barberId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Delete Booking (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/bookings/{{bookingId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "bookings",
            "{{bookingId}}"
          ]
        }
      }
    },
    {
      "name": "Delete Slot (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/slots/{{slotId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "slots",
            "{{slotId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://test-4p5l.onrender.com"
    },
    {
      "key": "adminUser",
      "value": "admin"
    },
    {
      "key": "adminPassword",
      "value": "change-me"
    },
    {
      "key": "userFullName",
      "value": "Test User"
    },
    {
